# ============================
# SentinelOps Environment Configuration
# ============================
# Copy this file to `.env` in both the project root and backend/ directory.
#   cp .env.example .env
#   cp .env.example backend/.env

# ----- Database -----
# SQLite (default — works out of the box, no external dependencies):
DATABASE_URL=sqlite:///./sentinelops.db
# PostgreSQL (for Docker Compose or production):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinelops
# Docker Compose internal network:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sentinelops

# ----- Telemetry Source -----
# "google_scale" = Google-scale microservices simulator (9 services, realistic traffic)
# "simulation"   = Simple 5-service local simulation
TELEMETRY_SOURCE=google_scale

# ----- Redis (optional, not required for SQLite mode) -----
REDIS_URL=redis://localhost:6379/0

# ----- LLM Configuration -----
# "demo" = Fully deterministic offline mode (no API keys required)
# "openai" / "anthropic" / "groq" = Live LLM agents (requires API key below)
LLM_PROVIDER=demo
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ----- Security -----
JWT_SECRET=change-me-in-production

# ----- Prometheus (optional) -----
PROMETHEUS_URL=http://localhost:9090
